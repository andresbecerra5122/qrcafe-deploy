# ===== QrCafe Docker Compose Environment =====

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=qrcafe

# .NET API - CORS (comma-separated origins, e.g. https://yourdomain.com)
ALLOWED_ORIGINS=https://yourdomain.com

# JWT for admin auth
JWT_SECRET=change_me_with_at_least_32_random_chars
JWT_ISSUER=QrCafe.Api
JWT_AUDIENCE=QrCafe.Admin
JWT_EXPIRY_MINUTES=480

# One-time bootstrap admin (optional)
BOOTSTRAP_ADMIN_RESTAURANT_ID=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Initial Admin
BOOTSTRAP_ADMIN_ROLE=Manager

# Host port for HTTP traffic (default 80)
HTTP_PORT=80
